{
  "name": "papier-backend",
  "version": "1.0.0",
  "description": "Papier 文档分享平台后端",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "seed": "ts-node src/seed.ts",
    "migrate": "ts-node src/migrations/run.ts",
    "reindex": "ts-node src/reindex-all.ts",
    "rebuild": "ts-node src/rebuild-all.ts",
    "reprocess": "ts-node src/reprocess-docs.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:retrieval": "ts-node src/eval-retrieval.ts",
    "eval:generation": "ts-node src/evaluate-generation.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@lancedb/lancedb": "^0.29.0",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "apache-arrow": "^18.1.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "pdf-parse": "^1.1.1",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.7.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
