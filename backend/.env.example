# 服务器配置
PORT=3000
CORS_ORIGIN=http://localhost:5173

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=papier

# JWT 配置
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d

# 默认用户（仅首次 seed 时生效）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin
USER_USERNAME=user
USER_PASSWORD=change_me_user

# AI LLM 配置（OpenAI 兼容）
MIMO_BASE_URL=https://api.deepseek.com/v1
MIMO_API_KEY=your_api_key
MIMO_MODEL=deepseek-chat
MIMO_TRAIN_MODEL=deepseek-v4-flash

# 忠实度审查（用推理模型避免自评盲区）
FAITHFULNESS_JUDGE_MODEL=deepseek-reasoner

# Embedding 配置
EMBED_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBED_API_KEY=your_embed_api_key
EMBED_MODEL=embedding-2

# Rerank 配置（可选，API 不可用时自动降级）
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=your_rerank_api_key
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B

# AI 调试日志开关
DEBUG_AI=false
